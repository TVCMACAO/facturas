# Copie este archivo a .env y complete los valores.

# Desarrollo: omitir o usar development. Producción (Docker/Easy Panel): production
FLASK_ENV=development

# Obligatoria en producción (generar clave aleatoria larga)
SECRET_KEY=cambiar-en-produccion

# MySQL: usar mysql+mysqlconnector:// (no mysql://)
# Local: mysql+mysqlconnector://user:password@localhost:3306/ventas
# Easy Panel: mysql+mysqlconnector://mysql:PASSWORD@chat_bd_cuentas:3306/ventas
DATABASE_URL=mysql+mysqlconnector://user:password@localhost:3306/ventas

# Servidor local (opcional)
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Docker / Easy Panel inyecta PORT (típicamente 5000)
PORT=5000

# Email (opcional)
MAIL_SERVER=smtp.googlemail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@yourdomain.com

# WhatsApp (opcional)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# OCR en entregas (Windows, opcional)
TESSERACT_CMD=

# Meta dashboard
MONTHLY_SALES_TARGET=10000.0
DEFAULT_TAX_RATE=0
